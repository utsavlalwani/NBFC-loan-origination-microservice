# App
APP_NAME=LoanFlow_API
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Security — generate a strong random value for production
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/loanflow
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# AWS — leave empty to use local mocks
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
SQS_QUEUE_URL=

# External APIs
CREDIT_BUREAU_URL=https://api.cibil.com/v3
CREDIT_BUREAU_API_KEY=
CREDIT_BUREAU_TIMEOUT=10

# Feature flags — set True only when the matching credentials above are filled in
USE_AWS_S3=False
USE_AWS_SQS=False
USE_REAL_CREDIT_BUREAU=False
